# ─── Azki DE Task — shared environment ───────────────────────────────
#
# NOTE: This .env is intentionally committed so the stack runs with a single
# `docker compose up` / `make demo`, with no extra setup. It contains only
# THROWAWAY LOCAL DEMO credentials for ephemeral containers that bind to
# localhost — there are no real/production secrets here.
#
# In production these values would NOT live in the repo: they would come from
# a secret manager (Vault / cloud secrets) or CI-injected env vars, exactly as
# described in the governance section of docs/technical-report.md. Treat this
# file as a convenience for local evaluation only.
#
COMPOSE_PROJECT_NAME=azki

# MySQL (the "production" OLTP users source)
MYSQL_ROOT_PASSWORD=rootpw
MYSQL_DATABASE=azki
MYSQL_USER=azki
MYSQL_PASSWORD=azkipw

# ClickHouse (analytical warehouse). The azki CLI reads these for every
# command; CH_HOST/CH_PORT default to localhost:8123 on the host and are
# overridden to clickhouse:8123 inside the compose network.
CLICKHOUSE_DB=azki
CLICKHOUSE_USER=azki
CLICKHOUSE_PASSWORD=azkipw
CH_HOST=localhost
CH_PORT=8123

# Kafka
KAFKA_TOPIC_EVENTS=user_events
KAFKA_BOOTSTRAP_INTERNAL=kafka:9092
KAFKA_BOOTSTRAP_HOST=localhost:29092
